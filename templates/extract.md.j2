---
source: "{{ source_file }}"
type: "{{ content_type }}"
title: "{{ title }}"
date: {{ date }}
source_type: "{{ source_type | default('documentation') }}"
layer: "{{ layer | default('learning') }}"
domains: {{ domains | default([]) | tojson_raw }}
topics: {{ topics | tojson_raw }}
people: {{ people | tojson_raw }}
products: {{ products | tojson_raw }}
confidentiality: "{{ confidentiality | default('internal') }}"
authority: "{{ authority | default('tribal') }}"
{% if client %}client: "{{ client }}"
{% endif %}{% if project %}project: "{{ project }}"
{% endif %}{% if valid_to %}valid_to: {{ valid_to }}
{% endif %}language: "{{ language }}"
quality: "{{ quality }}"
{% if duration_min %}duration_min: {{ duration_min }}
{% endif %}model: "{{ model }}"
{% if routing_reason %}routing_reason: "{{ routing_reason }}"
{% endif %}{% if prompt_version %}prompt_version: "{{ prompt_version }}"
{% endif %}tokens_used: {{ tokens_used }}
source_tool: "{{ source_tool | default('knowledge-extractor') }}"
schema_version: 2
extraction_version: {{ extraction_version | default(1) }}
depth: "{{ depth | default('standard') }}"
{% if doc_type %}doc_type: "{{ doc_type }}"
{% endif %}{% if key_facts %}key_facts: {{ key_facts | tojson_raw }}
{% endif %}{% if entities_mentioned %}entities_mentioned: {{ entities_mentioned | tojson_raw }}
{% endif %}{% if freshness %}source_path: "{{ freshness.source_path }}"
source_hash: "{{ freshness.source_hash }}"
source_mtime: "{{ freshness.source_mtime }}"
extracted_at: "{{ freshness.extracted_at }}"
{% endif %}{% if tags %}tags: {{ tags | tojson_raw }}
{% endif %}{% if overlay and doc_type %}{{ doc_type }}_overlay: {{ overlay | tojson_raw }}
{% endif %}---

# {{ title }}

{{ links_line }}

> Source: [Open original](file:///{{ source_file | replace('\\', '/') }})

{{ summary }}

{% if slides %}
{% set section_label = "Section" if source_file.endswith(".pdf") or source_file.endswith(".docx") else "Slide" %}
{% for slide in slides %}
## {{ section_label }} {{ slide.slide_number }}: {{ slide.slide_title }}
*{{ slide.timestamp_approx }}*

![{{ section_label }} {{ slide.slide_number }}](../source/{{ slides_subdir | default('frames') }}/slide_{{ "%03d" | format(slide.slide_number) }}.png)

{{ slide.speaker_insight }}

{% if slide.so_what %}
**So what:** {{ slide.so_what }}
{% endif %}

{% if slide.critical_notes %}
> WARNING: {{ slide.critical_notes }}
{% endif %}

{% if slide.key_facts %}
**Key facts:**
{% for fact in slide.key_facts %}
- {{ fact }}
{% endfor %}
{% endif %}

---
{% endfor %}
{% endif %}

{% if slide_summaries %}
{% set section_label2 = "Section" if source_file.endswith(".pdf") or source_file.endswith(".docx") else "Slide" %}
{% for slide in slide_summaries %}
## {{ section_label2 }} {{ slide.slide_number }}: {{ slide.title }}

{{ slide.content }}

{% endfor %}
{% endif %}

{% if key_points %}
## Key Takeaways

{% for point in key_points %}
- {{ point }}
{% endfor %}
{% endif %}

{% if transcript_excerpt %}
## Notable Quotes

{{ transcript_excerpt }}
{% endif %}

{% if flagged_facts %}
## Flagged Facts

{% for ff in flagged_facts %}
> **{{ ff.verification_status | upper }}:** {{ ff.fact }}{% if ff.anomalies %}
> {{ ff.anomalies | join('; ') }}{% endif %}

{% endfor %}
{% endif %}
